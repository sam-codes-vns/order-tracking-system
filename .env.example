# Gmail credentials for OTP email delivery
# EMAIL_USER: your Gmail address (e.g. yourname@gmail.com)
# EMAIL_PASS: Gmail App Password (16 characters, no spaces)
#   How to generate: Google Account → Security → 2-Step Verification → App passwords
#   Select "Mail" and your device, then copy the generated 16-character password.
#   NOTE: Do NOT use your regular Gmail password — App Passwords are required.
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-16-character-app-password
